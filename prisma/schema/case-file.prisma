model CaseFile{
    id          String   @id @default(uuid())
    title       String
    description String?
    fileUrl     String   
    uploadedBy  User     @relation(fields: [userId], references: [id])
    userId      String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    casesummary CaseSummary?

    @@map("case_files")
}